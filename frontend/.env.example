# Local development
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000

# Speech-to-text: browser Web Speech API by default (use Chrome/Edge on localhost).
# Only set VITE_USE_WHISPER=true if you explicitly want OpenAI Whisper instead.
# VITE_USE_WHISPER=false

# Text-to-speech: browser SpeechSynthesis by default. Set VITE_USE_OPENAI_TTS=true
# for a natural OpenAI voice (needs OPENAI_API_KEY on the backend). Falls back
# to the browser voice automatically if the request fails.
# VITE_USE_OPENAI_TTS=false

# Production (Vercel) — set these in Vercel → Project → Settings → Environment Variables
# VITE_API_URL=https://YOUR-SERVICE.onrender.com/api
# VITE_SOCKET_URL=https://YOUR-SERVICE.onrender.com

# --- WebRTC TURN relay (cross-network video) ---
# TURN is configured on the BACKEND now (METERED_DOMAIN / METERED_API_KEY in
# backend/.env), so the secret key is never shipped to the browser. The
# frontend just fetches ready credentials from /api/tools/ice-servers.
#
# Optional escape hatch: paste a full ICE servers JSON array to override.
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
