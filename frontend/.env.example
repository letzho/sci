# Local development
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000

# Speech-to-text: browser Web Speech API by default (use Chrome/Edge on localhost).
# Only set VITE_USE_WHISPER=true if you explicitly want OpenAI Whisper instead.
# VITE_USE_WHISPER=false

# Production (Vercel) — set these in Vercel → Project → Settings → Environment Variables
# VITE_API_URL=https://YOUR-SERVICE.onrender.com/api
# VITE_SOCKET_URL=https://YOUR-SERVICE.onrender.com

# Optional: custom WebRTC ICE servers (JSON array). Defaults include STUN + public TURN on production.
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
