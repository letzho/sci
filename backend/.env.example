# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-random-string

# Database (Postgres - point this at a local Postgres install for dev, or a
# Supabase connection string for production: no code changes needed either
# way, since Supabase is itself managed Postgres).
# Local example:    postgres://postgres:postgres@localhost:5432/sci_copilot
# Supabase example (direct): postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Supabase example (Render — use Session pooler if ENETUNREACH IPv6):
#   postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sci_copilot
# Set to true when using Supabase if SSL connection fails (auto-detected for supabase.co URLs)
DATABASE_SSL=
# Set to false to disable IPv4-only DNS lookup for Supabase (not usually needed)
DATABASE_IPV4=

# Optional: enable live LLM-enhanced guidance, document/URL embeddings, and
# the no-deflection chat-draft prompt.
# Leave blank to run on the built-in rule/knowledge-base engine only (no key
# needed, fully offline, deterministic - uploaded documents still work via
# keyword matching, just without semantic search).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WHISPER_MODEL=whisper-1

# Optional: enable the Research Agent's live web search (Tavily) for
# questions the curated knowledge base / uploaded documents don't cover.
# Leave blank to skip web search - the AI will still ask a clarifying
# question instead of deflecting, it just won't have web facts to cite.
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# ML premium predictor (Python Flask sidecar in backend/ml/)
# Start locally: cd ml && pip install -r requirements.txt && python app.py
ML_SERVICE_URL=http://127.0.0.1:5001
ML_PORT=5001
